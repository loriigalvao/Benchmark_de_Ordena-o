<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Benchmark Ordenacao - Projeto III</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { 
            font-family: Arial, sans-serif; 
            max-width: 1200px; 
            margin: 0 auto; 
            padding: 20px; 
            background: #f5f5f5;
        }
        .container { 
            background: white; 
            padding: 30px; 
            border-radius: 10px; 
            box-shadow: 0 5px 15px rgba(0,0,0,0.1); 
        }
        button { 
            padding: 10px 20px; 
            margin: 10px; 
            background: #007bff; 
            color: white; 
            border: none; 
            border-radius: 5px; 
            cursor: pointer; 
        }
        button:hover { background: #0056b3; }
        button:disabled { background: #ccc; cursor: not-allowed; }
        table { 
            width: 100%; 
            border-collapse: collapse; 
            margin: 20px 0; 
        }
        th, td { 
            border: 1px solid #ddd; 
            padding: 8px; 
            text-align: center; 
        }
        th { 
            background: #007bff; 
            color: white; 
        }
        .melhor { 
            background: #d4edda; 
            font-weight: bold; 
        }
        .chart-container { 
            height: 400px; 
            margin: 20px 0; 
        }
        .loading { 
            text-align: center; 
            padding: 50px; 
            font-size: 18px; 
        }
        h1, h2 { 
            color: #333; 
        }
        h1 { text-align: center; }
    </style>
</head>
<body>
    <div class="container">
        <h1>PROJETO III - Benchmark de Ordenacao</h1>
        
        <button onclick="executarBenchmark()">Executar Benchmark</button>
        <button onclick="limparResultados()">Limpar Resultados</button>
        
        <div id="loading" style="display:none;">
            Executando testes... Aguarde...
        </div>
        
        <h2>Grafico de Desempenho</h2>
        <div class="chart-container">
            <canvas id="chartTempo"></canvas>
        </div>
        
        <h2>Resultados - Tempo Medio (ms) - Caso Aleatorio</h2>
        <table id="tabelaResultados">
            <thead>
                <tr>
                    <th>Tamanho</th>
                    <th>Bubble Sort</th>
                    <th>Insertion Sort</th>
                    <th>Merge Sort</th>
                    <th>Quick Sort</th>
                    <th>Heap Sort</th>
                    <th>Melhor</th>
                </tr>
            </thead>
            <tbody id="corpoTabela"></tbody>
        </table>
        
        <h2>Analise Teorica - Complexidade</h2>
        <table style="margin-top: 20px;">
            <tr>
                <th>Algoritmo</th>
                <th>Melhor Caso</th>
                <th>Caso Medio</th>
                <th>Pior Caso</th>
            </tr>
            <tr>
                <td>Bubble Sort</td>
                <td>O(n)</td>
                <td>O(n²)</td>
                <td>O(n²)</td>
            </tr>
            <tr>
                <td>Insertion Sort</td>
                <td>O(n)</td>
                <td>O(n²)</td>
                <td>O(n²)</td>
            </tr>
            <tr>
                <td>Merge Sort</td>
                <td>O(n log n)</td>
                <td>O(n log n)</td>
                <td>O(n log n)</td>
            </tr>
            <tr>
                <td>Quick Sort</td>
                <td>O(n log n)</td>
                <td>O(n log n)</td>
                <td>O(n²)</td>
            </tr>
            <tr>
                <td>Heap Sort</td>
                <td>O(n log n)</td>
                <td>O(n log n)</td>
                <td>O(n log n)</td>
            </tr>
        </table>
    </div>

    <script>
        class BenchmarkOrdenacao {
            constructor() {
                this.resultados = {};
                this.contadorComparacoes = 0;
            }

            bubbleSort(arr) {
                let n = arr.length;
                this.contadorComparacoes = 0;
                for (let i = 0; i < n-1; i++) {
                    for (let j = 0; j < n-i-1; j++) {
                        this.contadorComparacoes++;
                        if (arr[j] > arr[j+1]) {
                            [arr[j], arr[j+1]] = [arr[j+1], arr[j]];
                        }
                    }
                }
                return arr;
            }

            insertionSort(arr) {
                let n = arr.length;
                this.contadorComparacoes = 0;
                for (let i = 1; i < n; i++) {
                    let key = arr[i];
                    let j = i - 1;
                    while (j >= 0 && arr[j] > key) {
                        this.contadorComparacoes++;
                        arr[j+1] = arr[j];
                        j--;
                    }
                    this.contadorComparacoes++;
                    arr[j+1] = key;
                }
                return arr;
            }

            mergeSort(arr) {
                if (arr.length <= 1) return arr;
                let meio = Math.floor(arr.length / 2);
                let esquerda = this.mergeSort(arr.slice(0, meio));
                let direita = this.mergeSort(arr.slice(meio));
                return this.merge(esquerda, direita);
            }

            merge(esquerda, direita) {
                let resultado = [];
                let i = 0, j = 0;
                this.contadorComparacoes = 0;
                
                while (i < esquerda.length && j < direita.length) {
                    this.contadorComparacoes++;
                    if (esquerda[i] <= direita[j]) {
                        resultado.push(esquerda[i++]);
                    } else {
                        resultado.push(direita[j++]);
                    }
                }
                return resultado.concat(esquerda.slice(i)).concat(direita.slice(j));
            }

            quickSort(arr) {
                if (arr.length <= 1) return arr;
                let pivo = arr[arr.length - 1];
                let esquerda = [];
                let direita = [];
                this.contadorComparacoes = 0;
                
                for (let i = 0; i < arr.length - 1; i++) {
                    this.contadorComparacoes++;
                    if (arr[i] < pivo) {
                        esquerda.push(arr[i]);
                    } else {
                        direita.push(arr[i]);
                    }
                }
                return this.quickSort(esquerda).concat([pivo], this.quickSort(direita));
            }

            heapSort(arr) {
                let n = arr.length;
                this.contadorComparacoes = 0;
                
                for (let i = Math.floor(n/2) - 1; i >= 0; i--) {
                    this.heapify(arr, n, i);
                }
                
                for (let i = n-1; i > 0; i--) {
                    [arr[0], arr[i]] = [arr[i], arr[0]];
                    this.heapify(arr, i, 0);
                }
                return arr;
            }

            heapify(arr, n, i) {
                let maior = i;
                let esq = 2*i + 1;
                let dir = 2*i + 2;

                if (esq < n) {
                    this.contadorComparacoes++;
                    if (arr[esq] > arr[maior]) maior = esq;
                }
                if (dir < n) {
                    this.contadorComparacoes++;
                    if (arr[dir] > arr[maior]) maior = dir;
                }

                if (maior !== i) {
                    [arr[i], arr[maior]] = [arr[maior], arr[i]];
                    this.heapify(arr, n, maior);
                }
            }

            gerarArray(tamanho, tipo = 'aleatorio') {
                let arr = [];
                for (let i = 0; i < tamanho; i++) {
                    arr.push(Math.floor(Math.random() * 1000));
                }
                
                if (tipo === 'ordenado') {
                    arr.sort((a, b) => a - b);
                } else if (tipo === 'reverso') {
                    arr.sort((a, b) => b - a);
                }
                return arr;
            }

            medirTempo(algoritmo, tamanho, tipo) {
                const arrayOriginal = this.gerarArray(tamanho, tipo);
                const arrayCopia = [...arrayOriginal];
                
                const inicio = performance.now();
                switch(algoritmo) {
                    case 'bubble': this.bubbleSort(arrayCopia); break;
                    case 'insertion': this.insertionSort(arrayCopia); break;
                    case 'merge': this.mergeSort(arrayCopia); break;
                    case 'quick': this.quickSort(arrayCopia); break;
                    case 'heap': this.heapSort(arrayCopia); break;
                }
                const fim = performance.now();
                
                return fim - inicio;
            }

            executarBenchmark() {
                document.getElementById('loading').style.display = 'block';
                
                const tamanhos = [100, 1000, 5000, 10000];
                const algoritmos = ['bubble', 'insertion', 'merge', 'quick', 'heap'];
                
                this.resultados = {};
                
                tamanhos.forEach(tamanho => {
                    this.resultados[tamanho] = {};
                    algoritmos.forEach(algoritmo => {
                        let tempos = [];
                        // 3 execucoes para media
                        for (let i = 0; i < 3; i++) {
                            tempos.push(this.medirTempo(algoritmo, tamanho, 'aleatorio'));
                        }
                        this.resultados[tamanho][algoritmo] = (tempos.reduce((a,b)=>a+b)/3).toFixed(2);
                    });
                });
                
                setTimeout(() => {
                    this.mostrarResultados();
                    document.getElementById('loading').style.display = 'none';
                }, 100);
            }

            mostrarResultados() {
                this.criarGrafico();
                this.criarTabela();
            }

            criarGrafico() {
                const ctx = document.getElementById('chartTempo').getContext('2d');
                const tamanhos = [100, 1000, 5000, 10000];
                const labels = tamanhos.map(n => `N=${n}`);
                
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [
                            { label: 'Bubble Sort', data: tamanhos.map(n => this.resultados[n]?.bubble || 0), borderColor: 'red', tension: 0.1 },
                            { label: 'Insertion Sort', data: tamanhos.map(n => this.resultados[n]?.insertion || 0), borderColor: 'orange', tension: 0.1 },
                            { label: 'Merge Sort', data: tamanhos.map(n => this.resultados[n]?.merge || 0), borderColor: 'green', tension: 0.1 },
                            { label: 'Quick Sort', data: tamanhos.map(n => this.resultados[n]?.quick || 0), borderColor: 'blue', tension: 0.1 },
                            { label: 'Heap Sort', data: tamanhos.map(n => this.resultados[n]?.heap || 0), borderColor: 'purple', tension: 0.1 }
                        ]
                    },
                    options: {
                        scales: {
                            y: { type: 'logarithmic', title: { display: true, text: 'Tempo (ms)' } }
                        }
                    }
                });
            }

            criarTabela() {
                const tbody = document.getElementById('corpoTabela');
                tbody.innerHTML = '';
                
                const tamanhos = [100, 1000, 5000, 10000];
                const algoritmos = ['bubble', 'insertion', 'merge', 'quick', 'heap'];
                
                tamanhos.forEach(tamanho => {
                    const row = document.createElement('tr');
                    let html = `<td>${tamanho}</td>`;
                    let melhorTempo = Infinity;
                    let melhorAlgoritmo = '';
                    
                    algoritmos.forEach(algoritmo => {
                        const tempo = parseFloat(this.resultados[tamanho]?.[algoritmo] || 0);
                        html += `<td>${tempo.toFixed(2)} ms</td>`;
                        if (tempo < melhorTempo && tempo > 0) {
                            melhorTempo = tempo;
                            melhorAlgoritmo = algoritmo;
                        }
                    });
                    
                    html += `<td class="melhor">${melhorAlgoritmo.toUpperCase()}</td>`;
                    row.innerHTML = html;
                    tbody.appendChild(row);
                });
            }
        }

        const benchmark = new BenchmarkOrdenacao();

        function executarBenchmark() {
            benchmark.executarBenchmark();
        }

        function limparResultados() {
            document.getElementById('corpoTabela').innerHTML = '';
            const canvas = document.getElementById('chartTempo');
            const ctx = canvas.getContext('2d');
            ctx.clearRect(0, 0, canvas.width, canvas.height);
        }
    </script>
</body>
</html>